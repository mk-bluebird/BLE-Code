aln schema BciStreamProfileOpenBciCytonV1
version 1.0.0

enum OpenBciMessageKindV1
  StartStream
  StopStream
  SoftReset
  QueryBoard
  ChannelConfig
  RawFrame

enum OpenBciFrameFormatV1
  V3Ascii
  V3Binary

enum OpenBciFrameTypeV1
  OpenBCI_V3_SAMPLE
  OpenBCI_V3_SAMPLE_BINARY
  OpenBCI_IMPEDANCE_SAMPLE
  OpenBCI_SYSTEM_STATUS

enum OpenBciCommandByteV1
  StartStream
  StopStream
  SoftReset
  ChannelConfig
  ImpedanceStart
  ImpedanceStop
  SetSampleRate250
  SetSampleRate500
  SetSampleRate1000
  UserDefinedA
  UserDefinedB
  UserDefinedC

enum BciNeurorightsTagV1
  BciRawSignal
  BciMentalState
  BciBiometricId
  BciBasicTelemetry

enum BciFrameRiskBandV1
  VeryLow
  Low
  Medium
  High

record CommandPolicyV1
  kind          OpenBciMessageKindV1
  cmd_byte      OpenBciCommandByteV1
  roh_weight    float
  allowed       bool
  description   string

record FramePolicyV1
  format              OpenBciFrameFormatV1
  frametype           OpenBciFrameTypeV1
  marker              string
  max_channels        u32
  max_sample_rate_hz  u32
  bytes_per_frame     u32
  neurorights_tag     BciNeurorightsTagV1
  riskband            BciFrameRiskBandV1
  roh_weight          float

record OpenBciFrameProfileV1
  frametype        OpenBciFrameTypeV1
  marker           string
  sampleratehz     float
  channelcount     u32
  bytes_per_frame  u32
  neurorightstag   BciNeurorightsTagV1
  riskband         BciFrameRiskBandV1
  rohweight        float

record OpenBciCommandProfileV1
  cmd            string
  description    string
  allowed        bool
  neurorightstag BciNeurorightsTagV1
  rohweight      float

record BciStreamProfileOpenBciCytonV1
  streamid                string
  device_classid          string
  serviceuuid_rx          string
  serviceuuid_tx          string
  roh_ceiling             float
  commands                CommandPolicyV1
  frames                  FramePolicyV1
  frame_profiles          OpenBciFrameProfileV1
  command_profiles        OpenBciCommandProfileV1

invariant roh_weight_bounds
  forall cmd in commands
    cmd.roh_weight >= 0.0
    cmd.roh_weight <= 0.15

  forall frame in frames
    frame.roh_weight >= 0.0
    frame.roh_weight <= 0.15

invariant roh_ceiling_upperbound
  roh_ceiling <= 0.15

invariant non_negative_frame_roh
  forall f in frame_profiles
    f.rohweight >= 0.0

invariant non_negative_command_roh
  forall c in command_profiles
    c.rohweight >= 0.0

invariant bci_stream_roh_budget
  let total_frames = sum f.roh_weight for f in frames
  let total_cmds   = sum c.roh_weight for c in commands
  let total        = total_frames + total_cmds
  total <= roh_ceiling

profile BciStreamProfileOpenBciCytonV1_Default
  streamid       "openbci-cyton-nus-default"
  device_classid "openbci-cyton-nus"
  serviceuuid_rx "6E400001-B5A3-F393-E0A9-E50E24DCCA9E"
  serviceuuid_tx "6E400002-B5A3-F393-E0A9-E50E24DCCA9E"
  roh_ceiling    0.15

  commands
    CommandPolicyV1
      kind        StartStream
      cmd_byte    StartStream
      roh_weight  0.03
      allowed     true
      description "Start acquisition with preconfigured channels."

    CommandPolicyV1
      kind        StopStream
      cmd_byte    StopStream
      roh_weight  0.01
      allowed     true
      description "Stop acquisition."

    CommandPolicyV1
      kind        SoftReset
      cmd_byte    SoftReset
      roh_weight  0.01
      allowed     true
      description "Soft reset of board state."

    CommandPolicyV1
      kind        QueryBoard
      cmd_byte    UserDefinedA
      roh_weight  0.01
      allowed     true
      description "Read board info and status."

    CommandPolicyV1
      kind        ChannelConfig
      cmd_byte    ChannelConfig
      roh_weight  0.05
      allowed     true
      description "Configure channel gains and filters with bounded RoH."

    CommandPolicyV1
      kind        RawFrame
      cmd_byte    UserDefinedB
      roh_weight  0.04
      allowed     true
      description "Implicit permission to receive raw frames."

  frames
    FramePolicyV1
      format             V3Ascii
      frametype          OpenBCI_V3_SAMPLE
      marker             "D"
      max_channels       8
      max_sample_rate_hz 250
      bytes_per_frame    33
      neurorights_tag    BciRawSignal
      riskband           Medium
      roh_weight         0.04

    FramePolicyV1
      format             V3Binary
      frametype          OpenBCI_V3_SAMPLE_BINARY
      marker             "d"
      max_channels       8
      max_sample_rate_hz 250
      bytes_per_frame    33
      neurorights_tag    BciRawSignal
      riskband           Medium
      roh_weight         0.04

  frame_profiles
    OpenBciFrameProfileV1
      frametype        OpenBCI_V3_SAMPLE
      marker           "D"
      sampleratehz     250.0
      channelcount     8
      bytes_per_frame  33
      neurorightstag   BciRawSignal
      riskband         Medium
      rohweight        0.04

    OpenBciFrameProfileV1
      frametype        OpenBCI_V3_SAMPLE_BINARY
      marker           "d"
      sampleratehz     250.0
      channelcount     8
      bytes_per_frame  33
      neurorightstag   BciRawSignal
      riskband         Medium
      rohweight        0.04

  command_profiles
    OpenBciCommandProfileV1
      cmd            "b"
      description    "Start streaming frames."
      allowed        true
      neurorightstag BciRawSignal
      rohweight      0.03

    OpenBciCommandProfileV1
      cmd            "s"
      description    "Stop streaming frames."
      allowed        true
      neurorightstag BciBasicTelemetry
      rohweight      0.01

    OpenBciCommandProfileV1
      cmd            "v"
      description    "Soft reset of board."
      allowed        true
      neurorightstag BciBasicTelemetry
      rohweight      0.01

    OpenBciCommandProfileV1
      cmd            "x"
      description    "Configure channel parameters."
      allowed        true
      neurorightstag BciRawSignal
      rohweight      0.05
