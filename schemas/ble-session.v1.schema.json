{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aln.local/schemas/ble-session.v1.schema.json",
  "title": "BleSessionV1",
  "type": "object",
  "required": [
    "session_id",
    "subject_id",
    "class_id",
    "device_id",
    "link",
    "roh",
    "energy",
    "kerew"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Globally unique session identifier (UUID).",
      "format": "uuid"
    },
    "subject_id": {
      "type": "string",
      "description": "Subject identifier, must match SubjectProfile.subject_id."
    },
    "class_id": {
      "type": "string",
      "description": "Device class identifier (e.g., openbci-cyton-nus)."
    },
    "device_id": {
      "type": "string",
      "description": "Concrete device identifier (MAC or adapter-specific ID)."
    },
    "started_at_utc": {
      "type": "string",
      "description": "ISO-8601 start timestamp.",
      "format": "date-time"
    },
    "ended_at_utc": {
      "type": ["string", "null"],
      "description": "ISO-8601 end timestamp; null if ongoing.",
      "format": "date-time"
    },
    "link": {
      "type": "object",
      "required": [
        "phy",
        "encrypted",
        "mic_present",
        "bonded",
        "conn_interval_ms",
        "max_pdu_bytes",
        "cte_present"
      ],
      "properties": {
        "phy": {
          "type": "string",
          "enum": ["LE1M", "LE2M", "LECodedS2", "LECodedS8"]
        },
        "encrypted": {
          "type": "boolean"
        },
        "mic_present": {
          "type": "boolean"
        },
        "bonded": {
          "type": "boolean"
        },
        "conn_interval_ms": {
          "type": "integer",
          "minimum": 7,
          "description": "Connection interval in milliseconds."
        },
        "max_pdu_bytes": {
          "type": "integer",
          "minimum": 23,
          "description": "Negotiated PDU/MTU size in bytes."
        },
        "cte_present": {
          "type": "boolean",
          "description": "Whether CTE is present on this link."
        }
      },
      "additionalProperties": false
    },
    "roh": {
      "type": "object",
      "required": [
        "roh_ceiling",
        "roh_used_ble",
        "roh_used_other",
        "roh_remaining"
      ],
      "properties": {
        "roh_ceiling": {
          "type": "number",
          "maximum": 0.3,
          "description": "Global RoH ceiling for this subject/session."
        },
        "roh_used_ble": {
          "type": "number",
          "minimum": 0.0,
          "description": "RoH consumed via BLE BCI services in this session."
        },
        "roh_used_other": {
          "type": "number",
          "minimum": 0.0,
          "description": "RoH consumed via other channels (non-BLE)."
        },
        "roh_remaining": {
          "type": "number",
          "minimum": 0.0,
          "description": "Remaining RoH budget at session close."
        }
      },
      "additionalProperties": false
    },
    "energy": {
      "type": "object",
      "required": ["joules", "carbon_kg"],
      "properties": {
        "joules": {
          "type": "number",
          "minimum": 0.0,
          "description": "Estimated energy consumption attributable to this BLE session."
        },
        "carbon_kg": {
          "type": "number",
          "minimum": 0.0,
          "description": "Estimated carbon impact (kg CO2e)."
        }
      },
      "additionalProperties": false
    },
    "kerew": {
      "type": "object",
      "required": ["knowledge_factor", "eco_wealth"],
      "properties": {
        "knowledge_factor": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Knowledge gain scalar K for this session."
        },
        "eco_wealth": {
          "type": "number",
          "description": "Composite EcoWealth score EW for this session."
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "string",
      "description": "Optional human/agent annotations."
    }
  },
  "additionalProperties": false
}
